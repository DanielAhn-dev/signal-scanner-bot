{
  "name": "signal-scanner-bot",
  "type": "commonjs",
  "version": "1.0.2",
  "packageManager": "pnpm@10.0.0",
  "description": "Telegram Stock Signal Scanner Bot with Vercel Functions",
  "private": true,
  "scripts": {
    "local": "pnpm dlx vercel dev",
    "build": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "docs:guide:pdf": "tsx scripts/export_markdown_pdf.ts --input docs/user-operating-guide.md --output docs/generated/user-operating-guide.pdf --title \"Signal Scanner Bot 운영 가이드\"",
    "docs:guide:pdf:check": "tsx scripts/export_markdown_pdf.ts --input docs/user-operating-guide.md --output docs/generated/user-operating-guide.pdf --title \"Signal Scanner Bot 운영 가이드\" --check",
    "verify:fundamental-parser": "tsx scripts/verify_fundamental_parser.ts",
    "audit:fundamental-live": "tsx scripts/audit_fundamental_live.ts",
    "verify:vercel": "pnpm build",
    "deploy": "pnpm dlx vercel --prod",
    "sync:scores": "tsx scripts/sync_scores_from_engine.ts",
    "seed:sectors": "tsx scripts/seedSectors.ts",
    "gen:sectors": "tsx scripts/generateSectorsJson.ts",
    "set:commands": "tsx scripts/ops/set_commands.ts",
    "autotrade:dry-run": "tsx scripts/ops/virtual_autotrade_dry_run.ts",
    "autotrade:run": "tsx scripts/ops/virtual_autotrade_run.ts",
    "autotrade:enable": "tsx scripts/ops/virtual_autotrade_enable.ts",
    "ops:rollback-trade": "tsx scripts/ops/rollback_virtual_trade.ts",
    "report:strategy-live": "tsx scripts/strategy_leaderboard.ts",
    "report:local": "tsx scripts/generate_local_reports.ts",
    "setWebhook": "node scripts/ops/setWebhook.mjs https://signal-scanner-bot.vercel.app/api/telegram",
    "backtest:market-picks": "tsx scripts/backtest_market_picks.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.45.0",
    "cheerio": "^1.1.2",
    "csv-parse": "^6.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^16.3.1",
    "iconv-lite": "^0.6.3",
    "pdf-lib": "^1.17.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/xlsx": "^0.0.35",
    "@vercel/node": "^5.7.7",
    "husky": "^9.1.7",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3"
  }
}
