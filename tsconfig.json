{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["api/**/*", "src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
