{
  "compilerOptions": {
    "target": "ES2020",
    "module": "es2020",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["api/**/*", "src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
