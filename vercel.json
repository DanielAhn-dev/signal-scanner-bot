{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "buildCommand": null,
    "devCommand": null,
    "installCommand": null,
    "ignoreCommand": "if [ \"$VERCEL_ENV\" = \"production\" ]; then exit 1; fi; git diff HEAD~1 --name-only | grep -qE '^web/'",
    "functions": {
        "api/economic-calendar.ts": {
            "maxDuration": 60
        },
        "api/market-overview.ts": {
            "maxDuration": 60
        },
        "api/ui.ts": {
            "maxDuration": 60
        },
        "api/telegram.ts": {
            "maxDuration": 15
        },
        "api/worker.ts": {
            "maxDuration": 60
        },
        "api/cron.ts": {
            "maxDuration": 60
        },
        "api/update.ts": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/getTelegramProfile",
            "destination": "/api/ui?route=telegram-profile"
        },
        {
            "source": "/api/getUserByTg",
            "destination": "/api/ui?route=telegram-profile"
        },
        {
            "source": "/api/economic-calendar",
            "destination": "/api/ui?route=economic-calendar"
        },
        {
            "source": "/portfolio/shared",
            "destination": "/api/ui/portfolio-shared"
        },
        {
            "source": "/report/shared",
            "destination": "/api/ui/report-shared"
        },
        {
            "source": "/scan/shared",
            "destination": "/api/ui/route-shared?kind=scan"
        },
        {
            "source": "/analyze/shared",
            "destination": "/api/ui/route-shared?kind=analyze"
        },
        {
            "source": "/api/ui/:route",
            "destination": "/api/ui?route=:route"
        },
        {
            "source": "/api/cron/:task",
            "destination": "/api/cron?task=:task"
        },
        {
            "source": "/api/update/:task",
            "destination": "/api/update?task=:task"
        }
    ],
    "outputDirectory": ".",
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "10 1 * * 1-5"
        },
        {
            "path": "/api/cron",
            "schedule": "20 4 * * 1-5"
        },
        {
            "path": "/api/cron",
            "schedule": "0 6 * * 1-5"
        },
        {
            "path": "/api/cron/scoreSync",
            "schedule": "25 9 * * 1-5"
        }
    ]
}