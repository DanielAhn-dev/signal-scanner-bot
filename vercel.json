{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "buildCommand": null,
    "devCommand": null,
    "installCommand": null,
    "functions": {
        "api/telegram.ts": {
            "maxDuration": 15
        },
        "api/worker.ts": {
            "maxDuration": 60
        },
        "api/cron/scoreSync.ts": {
            "maxDuration": 60
        }
    },
    "outputDirectory": ".",
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 23 * * *"
        },
        {
            "path": "/api/cron/scoreSync",
            "schedule": "40 6 * * 1-5"
        }
    ]
}