{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "buildCommand": null,
    "devCommand": null,
    "installCommand": null,
    "functions": {
        "api/telegram.ts": {
            "maxDuration": 15
        },
        "api/worker.ts": {
            "maxDuration": 60
        },
        "api/cron/scoreSync.ts": {
            "maxDuration": 60
        },
        "api/cron/briefing.ts": {
            "maxDuration": 60
        },
        "api/cron/report.ts": {
            "maxDuration": 60
        },
        "api/cron/strategyGateRefresh.ts": {
            "maxDuration": 60
        },
        "api/cron/virtualAutoTrade.ts": {
            "maxDuration": 60
        },
        "api/ui/report-pdf.ts": {
            "maxDuration": 60
        },
        "api/ui/report-web.ts": {
            "maxDuration": 60
        },
        "api/ui/report-snapshot.ts": {
            "maxDuration": 60
        },
        "api/ui/trigger-briefing.ts": {
            "maxDuration": 30
        },
        "api/ui/trigger-update.ts": {
            "maxDuration": 30
        },
        "api/ui/notify.ts": {
            "maxDuration": 30
        }
    },
    "outputDirectory": ".",
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 23 * * *"
        },
        {
            "path": "/api/cron/scoreSync",
            "schedule": "40 6 * * 1-5"
        }
    ]
}