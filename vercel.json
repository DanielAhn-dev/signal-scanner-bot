{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "buildCommand": null,
    "devCommand": null,
    "installCommand": null,
    "functions": {
        "api/telegram.ts": {
            "maxDuration": 15
        },
        "api/worker.ts": {
            "maxDuration": 60
        }
    },
    "outputDirectory": ".",
    "crons": [
        {
            "path": "/api/cron/scoreSync",
            "schedule": "40 6 * * 1-5"
        },
        {
            "path": "/api/cron/scoreSync",
            "schedule": "0 23 * * 0-4"
        },
        {
            "path": "/api/cron/briefing",
            "schedule": "30 23 * * 0-4"
        },
        {
            "path": "/api/cron/briefing",
            "schedule": "10 6 * * 1-5"
        },
        {
            "path": "/api/cron/report",
            "schedule": "35 23 * * 5"
        },
        {
            "path": "/api/cron/virtualAutoTrade",
            "schedule": "45 23 * * 0-4"
        },
        {
            "path": "/api/cron/virtualAutoTrade?mode=auto&dryRun=false&intradayOnly=true&windowMinutes=10&maxUsers=50",
            "schedule": "*/10 0-5 * * 1-5"
        },
        {
            "path": "/api/cron/virtualAutoTrade?mode=auto&dryRun=false&intradayOnly=true&windowMinutes=10&maxUsers=50",
            "schedule": "0,10,20 6 * * 1-5"
        }
    ]
}